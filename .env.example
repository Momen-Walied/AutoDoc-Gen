# AutoDoc-Gen environment variables
# Copy this file to .env and fill in real values.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
APP_NAME=autodoc-gen
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# ---------------------------------------------------------------------------
# PostgreSQL (metadata and state)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://autodocgen:autodocgen@localhost:5432/autodocgen

# ---------------------------------------------------------------------------
# Temporal (workflow orchestration)
# ---------------------------------------------------------------------------
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=autodoc-gen-task-queue

# ---------------------------------------------------------------------------
# Amazon S3 (artifact storage)
# ---------------------------------------------------------------------------
S3_BUCKET=autodocgen-artifacts
S3_ENDPOINT_URL=                     # Optional: override for MinIO/localstack
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# LiteLLM routing
# All LLM calls go through LiteLLM. Provider keys below are loaded on demand.
# ---------------------------------------------------------------------------
LITELLM_DEFAULT_MODEL=gpt-4o-mini           # Main / default model
LITELLM_FALLBACK_MODEL=gpt-4o-mini          # Fallback on failure/rate-limit

# Tiered model lists (comma-separated LiteLLM-compatible model strings)
# All values MUST be routed through LiteLLM.
BULK_TIER_MODELS=gpt-4o-mini,ollama_cloud/llama3.1:8b
REASONING_TIER_MODELS=gpt-4o,claude-3-5-sonnet-20240620,azure/gpt-4o,ollama_cloud/llama3.1:70b

# ---------------------------------------------------------------------------
# Provider API keys (only set the ones you actually use)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=
DEEPSEEK_API_KEY=

# Ollama Cloud (API-key based, not local Ollama)
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_API_BASE=https://api.ollama.cloud/v1

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
LANGTRACE_API_KEY=
LANGTRACE_ENDPOINT=https://app.langtrace.ai/api/trace

# ---------------------------------------------------------------------------
# GitHub (public repos only in MVP)
# ---------------------------------------------------------------------------
GITHUB_BASE_URL=https://github.com
